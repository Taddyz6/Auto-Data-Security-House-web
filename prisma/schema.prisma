generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum LeadSource {
  self_assessment
  consultation
  demo
  visit
}

enum LeadStatus {
  new
  contacted
  qualifying
  demo_scheduled
  visit_scheduled
  no_demand
  closed
}

enum LeadPreference {
  phone
  email
  wechat
  meeting
}

enum RecordTernary {
  yes
  no
  unknown
}

enum ResultLevel {
  basic
  process
  security_house
}

enum CaseStatus {
  example
  planned
  implemented
}

enum ResourceCategory {
  whitepaper
  checklist
  solution
  policy
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ConsultationLead {
  id                  String            @id @default(cuid())
  source              LeadSource
  companyName         String?
  contactName         String
  jobTitle            String?
  phone               String?
  email               String?
  preferredContact    LeadPreference?
  expectedContactTime String?
  message             String?
  consent             Boolean
  status              LeadStatus        @default(new)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  assessment          AssessmentRecord?
}

model AssessmentRecord {
  id                 String             @id @default(cuid())
  companyName        String?
  enterpriseType     String
  scenarios          Json
  transferDirection  String
  destinations       Json
  multipleCountries  Boolean
  dataTypes          Json
  frequency          String
  dataVolume         String
  currentChannels    Json
  hasApprovalProcess RecordTernary
  hasClassification  RecordTernary
  hasCompleteLogs    RecordTernary
  painPoints         Json
  complexityScore    Int
  sensitivityScore   Int
  maturityGapScore   Int
  totalScore         Int
  resultLevel        ResultLevel
  recommendations    Json
  focusItems         Json
  leadId             String?            @unique
  lead               ConsultationLead?  @relation(fields: [leadId], references: [id])
  createdAt          DateTime           @default(now())
}

model CaseItem {
  id             String     @id @default(cuid())
  title          String
  enterpriseType String
  scenario       String
  direction      String
  dataTypes      Json
  problem        String
  solution       String
  outcome        String
  status         CaseStatus
  anonymized     Boolean    @default(true)
  published      Boolean    @default(true)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model QualificationItem {
  id          String   @id @default(cuid())
  title       String
  issuer      String?
  issueDate   String?
  imageUrl    String?
  description String?
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResourceItem {
  id            String           @id @default(cuid())
  title         String
  category      ResourceCategory
  description   String?
  fileUrl       String
  coverUrl      String?
  published     Boolean          @default(true)
  downloadCount Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model FaqItem {
  id         String   @id @default(cuid())
  question   String
  answer     String
  published  Boolean  @default(true)
  sortOrder  Int      @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())
}
